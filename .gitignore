# dependencies
node_modules/
.pnp
.pnp.js

# build output
dist/
build/
out/
*.js.map

# compiled standalone binary (platform-specific, built via `bun run build:binary`)
bin/harness
bin/harness.exe

# bun.lock is intentionally NOT ignored — commit it like package-lock.json

# harness runtime state
# generated by `harness init` — contains session state, agent registrations,
# task queues, and inter-agent messages. machine-specific, never commit.
.harness/

# cursor workspace files written by harness at runtime
.cursor/harness-task.md
.cursor/harness-result.json
.cursor/rules/harness.mdc

# environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# windows
ehthumbs.db
Thumbs.db
desktop.ini

# editors
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
bun-error.log*

# test coverage
coverage/
.nyc_output/
*.lcov

# typescript
*.tsbuildinfo

# temp files
tmp/
temp/
*.tmp
*.bak
*.orig
