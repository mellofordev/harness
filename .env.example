# copy this file to .env and fill in values you need
# never commit .env to version control

# optional: override which directory harness uses for state
# HARNESS_DIR=.harness

# optional: default working directory
# HARNESS_WORK_DIR=.

# required by Claude Code CLI (set by the claude CLI itself, not harness)
# ANTHROPIC_API_KEY=your-key-here

# required by Codex CLI
# OPENAI_API_KEY=your-key-here

# required by Gemini CLI
# GOOGLE_API_KEY=your-key-here
