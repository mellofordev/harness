{
  "name": "harness-cli",
  "version": "0.2.0-alpha.0",
  "description": "Multi-agent AI orchestrator for Claude Code, Cursor, Codex, and Gemini CLI",
  "author": "sreedhar",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "claude-code",
    "cursor",
    "codex",
    "cli",
    "multi-agent",
    "automation"
  ],
  "bin": {
    "harness": "./bin/harness.ts"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "bin/",
    "src/",
    "examples/",
    "install.sh",
    "setup.sh",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun --sourcemap=external",
    "build:binary": "bun build src/cli.ts --compile --outfile dist/harness",
    "build:check": "tsc --noEmit",
    "start": "bun run dist/cli.js",
    "link": "bun link",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "react-devtools-core": "^7.0.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "typescript": "^5.0.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
